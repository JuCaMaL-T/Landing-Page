---
import "../styles/global.css";
import Header from "../components/layouts/Header.tsx";
const { children, mesh = false } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Jucamal Tecnología</title>
	</head>
	<body class="bg-slate-950 [&::-webkit-scrollbar]:hidden">
		{mesh ? (
		<div class="mesh-bg min-h-screen w-full relative">
			<Header client:load/>
				<slot />
		</div>
		) : (
			<Header client:load/>
				<slot />
		)}
	</body>
</html>